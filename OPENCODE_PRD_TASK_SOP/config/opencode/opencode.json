{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/minimax-m2.5-free",
  "instructions": [
    ".config/opencode/system-prompt.md"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "YOUR_CONTEXT7_API_KEY"
      },
      "enabled": true
    },
    "bright-data": {
      "type": "local",
      "command": ["npx", "@brightdata/mcp"],
      "environment": {
        "API_TOKEN": "YOUR_BRIGHTDATA_API_TOKEN"
      },
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_TOKEN"
      },
      "enabled": true
    },
    "airtable": {
      "type": "local",
      "command": ["npx", "-y", "airtable-mcp-server"],
      "environment": {
        "AIRTABLE_API_KEY": "YOUR_AIRTABLE_API_KEY"
      },
      "enabled": true
    },
    "shadcn-ui": {
      "type": "local",
      "command": ["npx", "@jpisnice/shadcn-ui-mcp-server", "--github-api-key", "YOUR_GITHUB_API_KEY"],
      "enabled": true
    },
    "supabase": {
      "type": "local",
      "command": ["npx", "-y", "@supabase/mcp-server-supabase@latest", "--access-token", "YOUR_SUPABASE_ACCESS_TOKEN"],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest", "--channel=canary", "--headless=true", "--isolated=true"],
      "enabled": true
    },
    "figma": {
      "type": "local",
      "command": ["npx", "-y", "figma-developer-mcp", "--figma-api-key=YOUR_FIGMA_API_KEY", "--stdio"],
      "enabled": true
    },
    "netlify": {
      "type": "local",
      "command": ["npx", "-y", "@netlify/mcp"],
      "environment": {
        "NETLIFY_PERSONAL_ACCESS_TOKEN": "YOUR_NETLIFY_TOKEN"
      },
      "enabled": true
    },
    "firecrawl": {
      "type": "local",
      "command": ["npx", "-y", "firecrawl-mcp"],
      "environment": {
        "FIRECRAWL_API_KEY": "YOUR_FIRECRAWL_API_KEY"
      },
      "enabled": true
    },
    "redis-mcp-server": {
      "type": "local",
      "command": ["uvx", "--from", "redis-mcp-server@latest", "redis-mcp-server", "--url", "YOUR_REDIS_URL"],
      "enabled": true
    }
  }
}